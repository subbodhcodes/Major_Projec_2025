// =============================================================================
// FILE: cim_top.v
// DESC: Top-level CIM MAC Core.
//       Instantiates and wires all submodules per the architecture diagram:
//
//         User/CIM inputs
//              │
//         ┌────▼────────┐    ┌──────────────┐
//         │ CIM Control │    │ SRAM Control │◄── User/BIST write
//         │  (FSM)      │    │  Circuit     │
//         └────┬────────┘    └──────┬───────┘
//              │ WL_auto             │ WS,WA,WAB,write_bus
//              │ WL_addend           │
//         ┌────▼────────────────────▼───────┐
//         │      Row Decoders (×3)          │
//         └────┬──────────────┬─────────────┘
//              │              │
//         ┌────▼──────────────▼─────────────┐
//         │         SRAM Array 8×8          │
//         └────┬──────────────┬─────────────┘
//              │BL            │BL_A, BL_B
//         ┌────▼────┐    ┌────▼────────────┐
//         │Col Dec  │    │Current Comp.    │
//         │Col Sel  │    │(CAND, CNOR)     │
//         └────┬────┘    └────┬────────────┘
//              │Data_out      │
//                        ┌────▼────────────┐
//                        │ FS-GDI Adder    │ ◄─ CB (accumulator register)
//                        │ (rrcam_8bit)    │
//                        └────┬────────────┘
//                             │SUM, CO, Sign
//                        ┌────▼────────────┐
//                        │  Write-Back     │
//                        │  (wb_circuit)   │
//                        └────┬────────────┘
//                             │Write_Data_Bus, WL_out, wr_en_wb
//                          (write arbitration)
//                             │
//                         SRAM Array (write port)
//
//   The accumulator register (acc_reg) stores SUM on DffC and feeds it back
//   as CB to the adder on the next MAC cycle — enabling multi-MAC chaining.
//
// Verilator command:
//   verilator --cc --exe --build --timing \
//     cim_submodules.v cim_top.v sim_main.cpp \
//     -o cim_sim --Wno-fatal
// =============================================================================
`timescale 1ns / 1ps

module cim_top (
    input  wire        clk,
    input  wire        rst_n,

    // ---- CIM / MAC operation interface ----
    input  wire        MUL,              // Trigger: 1-bit multiplication
    input  wire        CIM,              // Trigger: CIM accumulate (MAC)
    input  wire [2:0]  Augend_addr,      // SRAM row of operand A
    input  wire [2:0]  Addend_addr,      // SRAM row of operand B
    input  wire [2:0]  Product_addr,     // SRAM row to write MAC result
    input  wire [2:0]  Sign_addr,        // SRAM row to write MUL sign result

    // ---- Normal SRAM user interface ----
    input  wire [2:0]  Word_addr,        // Row address for normal R/W
    input  wire [2:0]  Bit_addr,         // Column address for normal R/W
    input  wire [7:0]  Data_in,          // Normal write data
    input  wire        wr_en,            // Normal write enable

    // ---- BIST interface ----
    input  wire [2:0]  bword_addr,       // BIST row address
    input  wire        BIST_data_in,     // BIST fill pattern (0 or 1, replicated)
    input  wire        BIST_wr_en,       // BIST write enable

    // ---- Read / result outputs ----
    output wire        Data_out,         // Column-selected single-bit read
    output wire [7:0]  SUM_out,          // 8-bit adder sum (combinational)
    output wire        CO_out,           // Final carry-out
    output wire        Sign_out,         // MSB of SUM (sign bit)
    output wire        Signproduct_out,  // XOR of MSBs (product sign for MUL)
    output wire        done              // Asserted when MAC/MUL complete
);

    // =========================================================================
    //  Internal Wires
    // =========================================================================

    // ---- CIM FSM outputs ----
    wire        Dffwr;
    wire        Cimprec;
    wire        WRSel;
    wire        Dffwrb;
    wire        DffC;
    wire [2:0]  WL_auto;      // Augend row (& write-back destination)
    wire [2:0]  WL_addend;    // Addend row
    wire [2:0]  BL_auto;      // Column address from FSM
    wire [2:0]  S_addr;       // Write-back destination row
    wire        Is_Mul;
    wire [2:0]  CIM_Data;
    wire        cim_active;   // CIM or MUL in progress

    // ---- SRAM Control outputs ----
    wire [2:0]  WS;           // Binary row select → row_decoder
    wire [7:0]  WA_sram;      // One-hot write address (registered)
    wire [7:0]  WAB_sram;     // Complement of WA
    wire [7:0]  PreD;         // Precharge control word
    wire [7:0]  write_bus_sram;
    wire        wr_en_sram;

    // ---- Row Decoder outputs (three decoders: normal, augend, addend) ----
    wire [7:0]  WL_normal;    // Normal read/write row
    wire [7:0]  WL_A;         // CIM augend row
    wire [7:0]  WL_B;         // CIM addend row

    // ---- SRAM Array outputs ----
    wire [7:0]  BL;           // Normal bit-lines
    wire [7:0]  BL_A;         // Augend row bit-lines
    wire [7:0]  BL_B;         // Addend row bit-lines

    // ---- Column decoder ----
    wire [7:0]  Col_EN;

    // ---- Current Compensation ----
    wire [7:0]  CAND;
    wire [7:0]  CNOR;

    // ---- FS-GDI Adder outputs ----
    wire [7:0]  SUM;
    wire        CO;
    wire        Sign;
    wire        Signproduct;

    // ---- Write-Back Circuit outputs ----
    wire [7:0]  Write_Data_Bus;
    wire [2:0]  WL_wb;
    wire [2:0]  BL_wb;
    wire        wr_en_wb;

    // ---- Write arbitration ----
    // Write-back from CIM FSM takes priority over normal user writes.
    wire [7:0]  final_WA;
    wire [7:0]  final_write_bus;
    wire        final_wr_en;

    // ---- Accumulator register ----
    // Feeds back SUM as CB (column bias) on next MAC cycle.
    // Cleared on reset or when not in CIM/MUL mode.
    reg  [7:0]  acc_reg;

    // =========================================================================
    //  Logic
    // =========================================================================

    assign cim_active = CIM | MUL;

    // Accumulator: latched on DffC (EXECUTE state), feeds adder CB next cycle
    always @(posedge clk or negedge rst_n) begin
        if (!rst_n)
            acc_reg <= 8'h00;
        else if (DffC)
            acc_reg <= SUM;
        else if (!cim_active)
            acc_reg <= 8'h00;   // Clear accumulator between operations
    end

    // Write arbitration: wb_circuit write takes priority over sram_ctrl write
    assign final_wr_en     = wr_en_wb | wr_en_sram;
    assign final_WA        = wr_en_wb ? (8'h01 << WL_wb) : WA_sram;
    assign final_write_bus = wr_en_wb ? Write_Data_Bus    : write_bus_sram;

    // =========================================================================
    //  Module Instantiations
    // =========================================================================

    // ---- CIM Control FSM ----
    cim_ctrl u_cim_ctrl (
        .clk          (clk),
        .rst_n        (rst_n),
        .MUL          (MUL),
        .CIM          (CIM),
        .Augend_addr  (Augend_addr),
        .Addend_addr  (Addend_addr),
        .Product_addr (Product_addr),
        .Sign_addr    (Sign_addr),
        .Dffwr        (Dffwr),
        .Cimprec      (Cimprec),
        .WRSel        (WRSel),
        .Dffwrb       (Dffwrb),
        .DffC         (DffC),
        .WL_auto      (WL_auto),
        .WL_addend    (WL_addend),
        .BL_auto      (BL_auto),
        .S_addr       (S_addr),
        .Is_Mul       (Is_Mul),
        .done         (done),
        .CIM_Data     (CIM_Data)
    );

    // ---- SRAM Control ----
    sram_ctrl u_sram_ctrl (
        .clk          (clk),
        .rst_n        (rst_n),
        .Dffwr        (Dffwr),
        .Cimprec      (Cimprec),
        .cim_active   (cim_active),
        .WL_auto      (WL_auto),
        .BL_auto      (BL_auto),
        .Word_addr    (Word_addr),
        .Bit_addr     (Bit_addr),
        .Data_in      (Data_in),
        .wr_en        (wr_en),
        .bword_addr   (bword_addr),
        .BIST_data_in (BIST_data_in),
        .BIST_wr_en   (BIST_wr_en),
        .WS           (WS),
        .WA           (WA_sram),
        .WAB          (WAB_sram),
        .PreD         (PreD),
        .write_bus    (write_bus_sram),
        .wr_en_out    (wr_en_sram)
    );

    // ---- Row Decoder: Normal SRAM access ----
    row_decoder_3to8 u_rdec_normal (
        .addr (WS),
        .WL   (WL_normal)
    );

    // ---- Row Decoder: CIM Augend Row ----
    row_decoder_3to8 u_rdec_A (
        .addr (WL_auto),
        .WL   (WL_A)
    );

    // ---- Row Decoder: CIM Addend Row ----
    row_decoder_3to8 u_rdec_B (
        .addr (WL_addend),
        .WL   (WL_B)
    );

    // ---- SRAM Array (8 × 8 bits) ----
    sram_8x8_array u_sram (
        .clk       (clk),
        .rst_n     (rst_n),
        .WA        (final_WA),
        .write_bus (final_write_bus),
        .wr_en     (final_wr_en),
        .WL        (WL_normal),
        .BL        (BL),
        .WL_A      (WL_A),
        .BL_A      (BL_A),
        .WL_B      (WL_B),
        .BL_B      (BL_B)
    );

    // ---- Column Decoder ----
    col_decoder_3to8 u_cdec (
        .WS     (WS),
        .Col_EN (Col_EN)
    );

    // ---- Column Selector (single-bit read output) ----
    col_selector_8to1 u_csel (
        .bitlines (BL),
        .sel_en   (Col_EN),
        .data_out (Data_out)
    );

    // ---- Current Compensation Circuit ----
    // Converts dual-row BL activation to CAND / CNOR digital words
    current_comp u_cc (
        .BL_A (BL_A),
        .BL_B (BL_B),
        .CAND (CAND),
        .CNOR (CNOR)
    );

    // ---- FS-GDI 8-bit Ripple-Carry Adder ----
    // CB = acc_reg (accumulated result from previous MAC cycle)
    // For first operation: acc_reg = 0 → CB = 0
    rrcam_8bit u_adder (
        .CAND        (CAND),
        .CNOR        (CNOR),
        .CB          (acc_reg),     // Accumulator feedback
        .SUM         (SUM),
        .CO          (CO),
        .Sign        (Sign),
        .Signproduct (Signproduct)
    );

    // ---- Auto-Switching Write-Back Circuit ----
    wb_circuit u_wb (
        .clk           (clk),
        .rst_n         (rst_n),
        .Cimprec       (Cimprec),
        .WRSel         (WRSel),
        .Is_Mul        (Is_Mul),
        .Dffwrb        (Dffwrb),
        .DffC          (DffC),
        .S_addr        (S_addr),
        .WL_auto       (WL_auto),
        .BL_auto       (BL_auto),
        .SUM           (SUM),
        .CO            (CO),
        .Sign          (Sign),
        .Signproduct   (Signproduct),
        .CIM_Data_bus  ({5'b00000, CIM_Data}),
        .Write_Data_Bus(Write_Data_Bus),
        .WL_out        (WL_wb),
        .BL_out        (BL_wb),
        .wr_en_wb      (wr_en_wb)
    );

    // =========================================================================
    //  Output assignments
    // =========================================================================
    assign SUM_out         = SUM;
    assign CO_out          = CO;
    assign Sign_out        = Sign;
    assign Signproduct_out = Signproduct;

endmodule
// ========================= END OF cim_top.v ==================================

// =============================================================================
// FILE: cim_tb.v
// DESC: Comprehensive testbench for cim_top.
//       Tests: SRAM write, CIM MAC, MUL, BIST, accumulator chain.
//
// Simulation (Icarus Verilog):
//   iverilog -o cim_sim cim_submodules.v cim_top.v cim_tb.v && vvp cim_sim
//
// Simulation (Verilator with --timing):
//   verilator --cc --exe --build --timing \
//     cim_submodules.v cim_top.v cim_tb.v \
//     -o cim_sim --Wno-fatal
//   ./obj_dir/cim_sim
//
// VCD Waveform (add +define+DUMP_VCD when compiling):
//   iverilog -DDUMP_VCD -o cim_sim cim_submodules.v cim_top.v cim_tb.v
// =============================================================================
`timescale 1ns / 1ps

module cim_tb;

    // =========================================================================
    //  Clock & Reset
    // =========================================================================
    reg clk;
    reg rst_n;

    initial clk = 1'b0;
    always  #5 clk = ~clk;   // 100 MHz clock (10 ns period)

    // =========================================================================
    //  DUT Port Signals
    // =========================================================================
    reg        MUL;
    reg        CIM;
    reg [2:0]  Augend_addr;
    reg [2:0]  Addend_addr;
    reg [2:0]  Product_addr;
    reg [2:0]  Sign_addr;
    reg [2:0]  Word_addr;
    reg [2:0]  Bit_addr;
    reg [7:0]  Data_in;
    reg        wr_en;
    reg [2:0]  bword_addr;
    reg        BIST_data_in;
    reg        BIST_wr_en;

    wire        Data_out;
    wire [7:0]  SUM_out;
    wire        CO_out;
    wire        Sign_out;
    wire        Signproduct_out;
    wire        done;

    // =========================================================================
    //  DUT Instantiation
    // =========================================================================
    cim_top dut (
        .clk             (clk),
        .rst_n           (rst_n),
        .MUL             (MUL),
        .CIM             (CIM),
        .Augend_addr     (Augend_addr),
        .Addend_addr     (Addend_addr),
        .Product_addr    (Product_addr),
        .Sign_addr       (Sign_addr),
        .Word_addr       (Word_addr),
        .Bit_addr        (Bit_addr),
        .Data_in         (Data_in),
        .wr_en           (wr_en),
        .bword_addr      (bword_addr),
        .BIST_data_in    (BIST_data_in),
        .BIST_wr_en      (BIST_wr_en),
        .Data_out        (Data_out),
        .SUM_out         (SUM_out),
        .CO_out          (CO_out),
        .Sign_out        (Sign_out),
        .Signproduct_out (Signproduct_out),
        .done            (done)
    );

    // =========================================================================
    //  Test infrastructure
    // =========================================================================
    integer pass_cnt;
    integer fail_cnt;

    // Helper: Wait for N falling edges of clock
    task wait_clk;
        input integer n;
        integer i;
        begin
            for (i = 0; i < n; i = i + 1)
                @(negedge clk);
        end
    endtask

    // Helper: Write one row to SRAM via normal user interface
    task sram_write;
        input [2:0] row;
        input [7:0] data;
        begin
            @(negedge clk);
            Word_addr = row;
            Data_in   = data;
            wr_en     = 1'b1;
            @(negedge clk);
            wr_en     = 1'b0;
            Data_in   = 8'h00;
        end
    endtask

    // Helper: Trigger CIM MAC and wait for done (with timeout)
    task cim_mac;
        input [2:0] aug;
        input [2:0] add;
        input [2:0] prod;
        integer     timeout;
        begin
            @(negedge clk);
            Augend_addr  = aug;
            Addend_addr  = add;
            Product_addr = prod;
            CIM          = 1'b1;
            timeout      = 0;
            @(negedge clk);
            // Poll done with timeout (max 20 cycles)
            while (!done && timeout < 20) begin
                @(negedge clk);
                timeout = timeout + 1;
            end
            if (timeout >= 20)
                $display("  [WARN] cim_mac: done not asserted within 20 cycles!");
            @(negedge clk);
            CIM = 1'b0;
            @(negedge clk);   // let FSM return to IDLE
        end
    endtask

    // Helper: Trigger MUL and wait for done
    task cim_mul;
        input [2:0] aug;
        input [2:0] add;
        input [2:0] sign_row;
        integer     timeout;
        begin
            @(negedge clk);
            Augend_addr = aug;
            Addend_addr = add;
            Sign_addr   = sign_row;
            MUL         = 1'b1;
            timeout     = 0;
            @(negedge clk);
            while (!done && timeout < 20) begin
                @(negedge clk);
                timeout = timeout + 1;
            end
            if (timeout >= 20)
                $display("  [WARN] cim_mul: done not asserted within 20 cycles!");
            @(negedge clk);
            MUL = 1'b0;
            @(negedge clk);
        end
    endtask

    // Helper: Check and report
    task check;
        input [7:0]  actual;
        input [7:0]  expected;
        input [63:0] test_num;
        begin
            if (actual === expected) begin
                $display("  [PASS] Test %0d: SUM=0x%02X  (expected 0x%02X)",
                         test_num, actual, expected);
                pass_cnt = pass_cnt + 1;
            end else begin
                $display("  [FAIL] Test %0d: SUM=0x%02X  (expected 0x%02X)",
                         test_num, actual, expected);
                fail_cnt = fail_cnt + 1;
            end
        end
    endtask

    // =========================================================================
    //  Waveform Dump (conditional — compile with +define+DUMP_VCD)
    // =========================================================================
    `ifdef DUMP_VCD
    initial begin
        $dumpfile("cim_tb.vcd");
        $dumpvars(0, cim_tb);
    end
    `endif

    // =========================================================================
    //  Timeout Watchdog
    // =========================================================================
    initial begin
        #50000;
        $display("[TIMEOUT] Simulation exceeded 50us — terminating.");
        $finish;
    end

    // =========================================================================
    //  Main Test Sequence
    // =========================================================================
    initial begin
        // ---- Initialise all inputs ----
        rst_n        = 1'b0;
        MUL          = 1'b0;
        CIM          = 1'b0;
        Augend_addr  = 3'd0;
        Addend_addr  = 3'd0;
        Product_addr = 3'd0;
        Sign_addr    = 3'd0;
        Word_addr    = 3'd0;
        Bit_addr     = 3'd0;
        Data_in      = 8'h00;
        wr_en        = 1'b0;
        bword_addr   = 3'd0;
        BIST_data_in = 1'b0;
        BIST_wr_en   = 1'b0;
        pass_cnt     = 0;
        fail_cnt     = 0;

        // ---- Release reset after 4 clock edges ----
        repeat(4) @(posedge clk);
        @(negedge clk);
        rst_n = 1'b1;
        @(negedge clk);

        $display("");
        $display("============================================================");
        $display("  CIM MAC Core Testbench  —  100 MHz  —  8-bit SRAM 8×8");
        $display("============================================================");

        // ==================================================================
        // TEST 1: SRAM write + readback sanity
        //   Write 0xA5 to row 0, verify Data_out on column 0 = bit[0] of 0xA5 = 1
        // ==================================================================
        $display("");
        $display("--- TEST 1: SRAM Write / Readback ---");
        sram_write(3'd0, 8'hA5);   // row 0 = 1010_0101
        sram_write(3'd1, 8'h5A);   // row 1 = 0101_1010
        sram_write(3'd2, 8'hFF);   // row 2 = 1111_1111
        sram_write(3'd3, 8'h00);   // row 3 = 0000_0000
        sram_write(3'd4, 8'hF0);   // row 4 = 1111_0000
        sram_write(3'd5, 8'h0F);   // row 5 = 0000_1111
        $display("  Written: row0=0xA5 row1=0x5A row2=0xFF row3=0x00 row4=0xF0 row5=0x0F");

        // Read column 0 of row 0 (bit 0 of 0xA5 = 1)
        @(negedge clk);
        Word_addr = 3'd0;
        Bit_addr  = 3'd0;
        @(negedge clk);
        if (Data_out === 1'b1) begin
            $display("  [PASS] Data_out col0/row0 = %b (expect 1)", Data_out);
            pass_cnt = pass_cnt + 1;
        end else begin
            $display("  [FAIL] Data_out col0/row0 = %b (expect 1)", Data_out);
            fail_cnt = fail_cnt + 1;
        end

        // Read column 1 of row 0 (bit 1 of 0xA5 = 0)
        @(negedge clk);
        Word_addr = 3'd0;
        Bit_addr  = 3'd1;
        @(negedge clk);
        if (Data_out === 1'b0) begin
            $display("  [PASS] Data_out col1/row0 = %b (expect 0)", Data_out);
            pass_cnt = pass_cnt + 1;
        end else begin
            $display("  [FAIL] Data_out col1/row0 = %b (expect 0)", Data_out);
            fail_cnt = fail_cnt + 1;
        end

        // ==================================================================
        // TEST 2: CIM MAC — complementary rows
        //   row0=0xA5 (1010_0101), row1=0x5A (0101_1010)
        //   CAND = 0xA5 & 0x5A = 0x00  (no bit both 1)
        //   CNOR = ~(0xA5 | 0x5A) = ~0xFF = 0x00 (all bits at least 1)
        //   P = CAND ^ CNOR = 0x00   (XNOR all 0: every bit differs → XNOR=0)
        //   SUM = P ^ CB ^ 0 = 0x00 ^ 0x00 = 0x00 (acc_reg=0 at start)
        //   CO  = 0
        //   Expected SUM = 0x00
        // ==================================================================
        $display("");
        $display("--- TEST 2: CIM MAC — complementary rows (XNOR=0 expected) ---");
        cim_mac(3'd0, 3'd1, 3'd6);
        $display("  Row0=0xA5, Row1=0x5A → XNOR=0x00, CB=0x00");
        $display("  SUM=0x%02X CO=%b Sign=%b", SUM_out, CO_out, Sign_out);
        check(SUM_out, 8'h00, 2);

        // ==================================================================
        // TEST 3: CIM MAC — identical rows (all bits equal → XNOR=1 everywhere)
        //   row4=0xF0, row5=0x0F — these differ on every bit
        //   CAND = 0xF0 & 0x0F = 0x00
        //   CNOR = ~(0xF0 | 0x0F) = ~0xFF = 0x00
        //   P = 0x00 → SUM = 0x00 (all bits differ, XNOR=0 everywhere)
        //   Now try rows 2 and 2 (same row: all bits 1)
        //   CAND = 0xFF & 0xFF = 0xFF
        //   CNOR = ~(0xFF | 0xFF) = 0x00
        //   P = 0xFF ^ 0x00 = 0xFF   (XNOR=1 on every bit since identical)
        //   CB  = acc_reg = 0x00 (reset between ops)
        //   SUM = 0xFF ^ 0x00 ^ 0 = 0xFF, CO = 0
        //   Expected SUM = 0xFF
        // ==================================================================
        $display("");
        $display("--- TEST 3: CIM MAC — same row twice (XNOR=0xFF expected) ---");
        // Re-write row 2 to 0xFF and row 7 to 0xFF to use as dual identical rows
        sram_write(3'd2, 8'hFF);
        sram_write(3'd7, 8'hFF);
        cim_mac(3'd2, 3'd7, 3'd6);
        $display("  Row2=0xFF, Row7=0xFF → XNOR=0xFF, CB=0x00");
        $display("  SUM=0x%02X CO=%b", SUM_out, CO_out);
        check(SUM_out, 8'hFF, 3);

        // ==================================================================
        // TEST 4: CIM MAC — all-zero rows (XNOR=1 since 0 XNOR 0 = 1)
        //   row3=0x00, row3=0x00 (read same row twice)
        //   CAND = 0x00 & 0x00 = 0x00
        //   CNOR = ~(0x00 | 0x00) = 0xFF
        //   P = 0x00 ^ 0xFF = 0xFF
        //   CB = 0x00
        //   SUM = 0xFF, CO = 0
        // ==================================================================
        $display("");
        $display("--- TEST 4: CIM MAC — both rows all-zeros (XNOR=0xFF) ---");
        sram_write(3'd3, 8'h00);
        sram_write(3'd6, 8'h00);   // use row 6 as second copy of all-zeros
        cim_mac(3'd3, 3'd6, 3'd6);
        $display("  Row3=0x00, Row6=0x00 → XNOR=0xFF, CB=0x00");
        $display("  SUM=0x%02X CO=%b", SUM_out, CO_out);
        check(SUM_out, 8'hFF, 4);

        // ==================================================================
        // TEST 5: MUL operation
        //   MUL writes Signproduct to Sign_addr row.
        //   Signproduct = CAND[7] XOR CB[7]
        //   row0=0xA5 (MSB=1), row1=0x5A (MSB=0)
        //   CAND[7] = A5[7] & 5A[7] = 1 & 0 = 0
        //   CB[7] = acc_reg[7] = 0
        //   Signproduct = 0 XOR 0 = 0
        //   wb_circuit writes {7'b0, Signproduct} = 0x00 to Sign row
        // ==================================================================
        $display("");
        $display("--- TEST 5: MUL sign computation ---");
        sram_write(3'd0, 8'hA5);
        sram_write(3'd1, 8'h5A);
        cim_mul(3'd0, 3'd1, 3'd7);
        $display("  Row0=0xA5 (MSB=1), Row1=0x5A (MSB=0)");
        $display("  Signproduct_out=%b (CAND[7] XOR CB[7] = 0 XOR 0 = 0)", Signproduct_out);
        if (Signproduct_out === 1'b0) begin
            $display("  [PASS] Signproduct = 0 as expected");
            pass_cnt = pass_cnt + 1;
        end else begin
            $display("  [FAIL] Signproduct = %b (expected 0)", Signproduct_out);
            fail_cnt = fail_cnt + 1;
        end

        // ==================================================================
        // TEST 6: BIST — fill row with all-ones
        // ==================================================================
        $display("");
        $display("--- TEST 6: BIST write all-ones to row 7 ---");
        @(negedge clk);
        bword_addr   = 3'd7;
        BIST_data_in = 1'b1;
        BIST_wr_en   = 1'b1;
        @(negedge clk);
        BIST_wr_en   = 1'b0;
        @(negedge clk);
        // Verify by reading back column 0 (should be 1)
        Word_addr = 3'd7;
        Bit_addr  = 3'd0;
        @(negedge clk);
        @(negedge clk);
        if (Data_out === 1'b1) begin
            $display("  [PASS] BIST row7 col0 = %b (expect 1)", Data_out);
            pass_cnt = pass_cnt + 1;
        end else begin
            $display("  [FAIL] BIST row7 col0 = %b (expect 1)", Data_out);
            fail_cnt = fail_cnt + 1;
        end

        // BIST fill with all-zeros
        @(negedge clk);
        bword_addr   = 3'd7;
        BIST_data_in = 1'b0;
        BIST_wr_en   = 1'b1;
        @(negedge clk);
        BIST_wr_en = 1'b0;
        @(negedge clk);
        Word_addr = 3'd7;
        @(negedge clk);
        @(negedge clk);
        if (Data_out === 1'b0) begin
            $display("  [PASS] BIST row7 col0 = %b (expect 0 after zero-fill)", Data_out);
            pass_cnt = pass_cnt + 1;
        end else begin
            $display("  [FAIL] BIST row7 col0 = %b (expect 0 after zero-fill)", Data_out);
            fail_cnt = fail_cnt + 1;
        end

        // ==================================================================
        // TEST 7: Back-to-back CIM MAC — accumulator chain
        //   MAC1: row2(0xFF) XNOR row7(0x00) → CNOR part:
        //     CAND = 0xFF & 0x00 = 0x00
        //     CNOR = ~(0xFF | 0x00) = 0x00
        //     P = 0x00 (all bits differ: 1 vs 0)
        //     SUM1 = 0x00, acc_reg → 0x00
        //   MAC2: row7(0x00) XNOR row7(0x00):
        //     CAND = 0x00, CNOR = 0xFF, P = 0xFF
        //     SUM2 = 0xFF ^ acc_reg(0x00) = 0xFF
        // ==================================================================
        $display("");
        $display("--- TEST 7: Back-to-back MAC accumulator chain ---");
        sram_write(3'd2, 8'hFF);
        sram_write(3'd7, 8'h00);
        // MAC 1: row2 XNOR row7 (all differ → SUM=0x00)
        cim_mac(3'd2, 3'd7, 3'd6);
        $display("  MAC1: 0xFF XNOR 0x00 → SUM=0x%02X (expect 0x00)", SUM_out);
        // MAC 2: row7 XNOR row7 (all equal → SUM=0xFF) + acc from MAC1=0x00
        sram_write(3'd5, 8'h00);
        cim_mac(3'd7, 3'd5, 3'd6);
        $display("  MAC2: 0x00 XNOR 0x00 + acc=0x00 → SUM=0x%02X (expect 0xFF)", SUM_out);
        check(SUM_out, 8'hFF, 7);

        // ==================================================================
        // TEST 8: Carry-out test
        //   Write 0xFF to two rows; run MAC with CB (acc_reg) = 0xFF after prev
        //   P = 0xFF, CB = SUM from prev (0xFF), CI=0
        //   SUM[0] = 1^1^0 = 0, CO[0]=1
        //   ... ripple carry propagates fully
        //   0xFF + 0xFF = 0x1FE → SUM=0xFE, CO=1
        // ==================================================================
        $display("");
        $display("--- TEST 8: Carry-out propagation ---");
        sram_write(3'd0, 8'hFF);
        sram_write(3'd1, 8'hFF);
        // First MAC: P=0xFF, CB=acc(0xFF from test7 MAC2)... wait acc was reset
        // between operations. Let's force it:
        // Run one MAC with identical rows to get acc=0xFF
        cim_mac(3'd0, 3'd1, 3'd6);   // P=0xFF, acc_in=0 → SUM=0xFF
        $display("  Primer MAC: SUM=0x%02X (loading acc_reg=0xFF)", SUM_out);
        // Now run again: P=0xFF, acc=0xFF → 0xFF+0xFF: SUM=0xFE CO=1
        cim_mac(3'd0, 3'd1, 3'd6);
        $display("  Carry MAC:  P=0xFF + CB=0xFF → SUM=0x%02X CO=%b (expect 0xFE, CO=1)",
                 SUM_out, CO_out);
        if (SUM_out === 8'hFE && CO_out === 1'b1) begin
            $display("  [PASS] SUM=0xFE CO=1");
            pass_cnt = pass_cnt + 1;
        end else begin
            $display("  [FAIL] SUM=0x%02X CO=%b (expected SUM=0xFE CO=1)", SUM_out, CO_out);
            fail_cnt = fail_cnt + 1;
        end

        // ==================================================================
        // Summary
        // ==================================================================
        $display("");
        $display("============================================================");
        $display("  Simulation Complete");
        $display("  PASS: %0d   FAIL: %0d   TOTAL: %0d",
                 pass_cnt, fail_cnt, pass_cnt + fail_cnt);
        $display("============================================================");

        #20;
        $finish;
    end

endmodule
