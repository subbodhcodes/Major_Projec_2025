// =============================================================================
// FILE: cim_submodules.v
// DESC: All leaf submodules for the 8-bit CIM (Compute-In-Memory) MAC Core.
//       Follows the architecture diagram:
//         SRAM Control → SRAM Array → Current Compensation → FS-GDI Adder
//         CIM Control  → Auto-Switch Write-Back → SRAM Array
//       Verilator-compatible, fully synthesizable (no delays, no $display).
// =============================================================================
`timescale 1ns / 1ps

// -----------------------------------------------------------------------------
// MODULE 1: sram_8x8_array
//   8 rows × 8-bit synchronous SRAM with:
//     - One write port (one-hot WA)
//     - One normal read port (one-hot WL → BL)
//     - Two CIM read ports for dual-row activation (WL_A, WL_B → BL_A, BL_B)
// -----------------------------------------------------------------------------
module sram_8x8_array (
    input  wire        clk,
    input  wire        rst_n,
    // Write interface
    input  wire [7:0]  WA,          // One-hot write row select
    input  wire [7:0]  write_bus,   // 8-bit write data
    input  wire        wr_en,       // Write enable (active-high)
    // Normal read (one-hot row select)
    input  wire [7:0]  WL,          // One-hot read row select
    output reg  [7:0]  BL,          // Bit-lines: data of selected row
    // CIM dual-row read (augend row)
    input  wire [7:0]  WL_A,        // One-hot: augend row
    output reg  [7:0]  BL_A,        // Augend row data
    // CIM dual-row read (addend row)
    input  wire [7:0]  WL_B,        // One-hot: addend row
    output reg  [7:0]  BL_B         // Addend row data
);
    // Storage: 8 rows of 8 bits
    reg [7:0] mem [0:7];

    // ---- Synchronous Write ----
    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            mem[0] <= 8'h00; mem[1] <= 8'h00;
            mem[2] <= 8'h00; mem[3] <= 8'h00;
            mem[4] <= 8'h00; mem[5] <= 8'h00;
            mem[6] <= 8'h00; mem[7] <= 8'h00;
        end else if (wr_en) begin
            if (WA[0]) mem[0] <= write_bus;
            if (WA[1]) mem[1] <= write_bus;
            if (WA[2]) mem[2] <= write_bus;
            if (WA[3]) mem[3] <= write_bus;
            if (WA[4]) mem[4] <= write_bus;
            if (WA[5]) mem[5] <= write_bus;
            if (WA[6]) mem[6] <= write_bus;
            if (WA[7]) mem[7] <= write_bus;
        end
    end

    // ---- Combinational Normal Read ----
    always @(*) begin
        if      (WL[0]) BL = mem[0];
        else if (WL[1]) BL = mem[1];
        else if (WL[2]) BL = mem[2];
        else if (WL[3]) BL = mem[3];
        else if (WL[4]) BL = mem[4];
        else if (WL[5]) BL = mem[5];
        else if (WL[6]) BL = mem[6];
        else if (WL[7]) BL = mem[7];
        else            BL = 8'h00;
    end

    // ---- Combinational CIM Read: Augend Row ----
    always @(*) begin
        if      (WL_A[0]) BL_A = mem[0];
        else if (WL_A[1]) BL_A = mem[1];
        else if (WL_A[2]) BL_A = mem[2];
        else if (WL_A[3]) BL_A = mem[3];
        else if (WL_A[4]) BL_A = mem[4];
        else if (WL_A[5]) BL_A = mem[5];
        else if (WL_A[6]) BL_A = mem[6];
        else if (WL_A[7]) BL_A = mem[7];
        else              BL_A = 8'h00;
    end

    // ---- Combinational CIM Read: Addend Row ----
    always @(*) begin
        if      (WL_B[0]) BL_B = mem[0];
        else if (WL_B[1]) BL_B = mem[1];
        else if (WL_B[2]) BL_B = mem[2];
        else if (WL_B[3]) BL_B = mem[3];
        else if (WL_B[4]) BL_B = mem[4];
        else if (WL_B[5]) BL_B = mem[5];
        else if (WL_B[6]) BL_B = mem[6];
        else if (WL_B[7]) BL_B = mem[7];
        else              BL_B = 8'h00;
    end
endmodule


// -----------------------------------------------------------------------------
// MODULE 2: row_decoder_3to8
//   3-bit binary address → 8-bit one-hot word-line
// -----------------------------------------------------------------------------
module row_decoder_3to8 (
    input  wire [2:0] addr,
    output reg  [7:0] WL
);
    always @(*) begin
        case (addr)
            3'd0: WL = 8'b0000_0001;
            3'd1: WL = 8'b0000_0010;
            3'd2: WL = 8'b0000_0100;
            3'd3: WL = 8'b0000_1000;
            3'd4: WL = 8'b0001_0000;
            3'd5: WL = 8'b0010_0000;
            3'd6: WL = 8'b0100_0000;
            3'd7: WL = 8'b1000_0000;
            default: WL = 8'h00;
        endcase
    end
endmodule


// -----------------------------------------------------------------------------
// MODULE 3: col_decoder_3to8
//   3-bit binary address → 8-bit one-hot column enable
// -----------------------------------------------------------------------------
module col_decoder_3to8 (
    input  wire [2:0] WS,
    output reg  [7:0] Col_EN
);
    always @(*) begin
        case (WS)
            3'd0: Col_EN = 8'b0000_0001;
            3'd1: Col_EN = 8'b0000_0010;
            3'd2: Col_EN = 8'b0000_0100;
            3'd3: Col_EN = 8'b0000_1000;
            3'd4: Col_EN = 8'b0001_0000;
            3'd5: Col_EN = 8'b0010_0000;
            3'd6: Col_EN = 8'b0100_0000;
            3'd7: Col_EN = 8'b1000_0000;
            default: Col_EN = 8'h00;
        endcase
    end
endmodule


// -----------------------------------------------------------------------------
// MODULE 4: col_selector_8to1
//   Selects one bit from 8-bit bitline vector using one-hot enable
// -----------------------------------------------------------------------------
module col_selector_8to1 (
    input  wire [7:0] bitlines,
    input  wire [7:0] sel_en,
    output wire       data_out
);
    assign data_out = |(bitlines & sel_en);
endmodule


// -----------------------------------------------------------------------------
// MODULE 5: current_comp  (Current Compensation Circuit)
//
//   Digital RTL model of the analog sense-amplifier / current-mirror that
//   resolves dual-activated bitline currents into two digital words:
//
//     CAND[i] = 1  iff  BL_A[i]=1  AND  BL_B[i]=1
//               (both cells discharge → strongest pull-down)
//
//     CNOR[i] = 1  iff  BL_A[i]=0  AND  BL_B[i]=0
//               (neither cell discharges → NOR condition)
//
//   Note: CAND[i] and CNOR[i] are MUTUALLY EXCLUSIVE — they cannot
//         both be 1 for the same bit position. This property is used
//         to simplify the carry logic in rrcam_cell.
// -----------------------------------------------------------------------------
module current_comp (
    input  wire [7:0] BL_A,
    input  wire [7:0] BL_B,
    output wire [7:0] CAND,   // AND of both rows
    output wire [7:0] CNOR    // NOR of both rows
);
    assign CAND = BL_A & BL_B;
    assign CNOR = ~(BL_A | BL_B);
endmodule


// -----------------------------------------------------------------------------
// MODULE 6: rrcam_cell  (FS-GDI Ripple-Carry Adder Cell)
//
//   One bit of the XNOR-accumulate chain used for CIM MAC operations.
//
//   Since CAND & CNOR == 0 (mutually exclusive), define:
//     P[i] = CAND[i] XOR CNOR[i]  =  CAND[i] OR CNOR[i]  =  XNOR(A[i], B[i])
//
//   Full-adder on (P, CB, CI):
//     SUMx = P  XOR CB  XOR CI
//     COx  = (P AND CB) OR (CI AND (P XOR CB))
//
//   This correctly computes XNOR-popcount accumulation used in Binary NNs
//   where: XNOR(weight, input) substitutes for 1-bit multiplication.
// -----------------------------------------------------------------------------
module rrcam_cell (
    input  wire CANDx,   // CAND bit i
    input  wire CNORx,   // CNOR bit i
    input  wire CBx,     // Column Bias (accumulate operand) bit i
    input  wire CIx,     // Carry in
    output wire SUMx,    // Sum bit i
    output wire COx      // Carry out
);
    // P = XNOR(row_A[i], row_B[i])
    // Since CAND & CNOR are mutually exclusive: P = CAND | CNOR = CAND ^ CNOR
    wire Px;
    assign Px   = CANDx ^ CNORx;
    // Corrected full-adder carry: (P&CB) | (CI & (P^CB))
    assign SUMx = Px ^ CBx ^ CIx;
    assign COx  = (Px & CBx) | (CIx & (Px ^ CBx));
endmodule


// -----------------------------------------------------------------------------
// MODULE 7: rrcam_8bit  (FS-GDI 8-bit Ripple-Carry Adder)
//
//   Chains 8 rrcam_cell instances to produce an 8-bit XNOR-accumulate result.
//   Carry ripples from bit 0 (LSB) to bit 7 (MSB).
//
//   Ports:
//     CAND[7:0]  — AND of the two activated SRAM rows (from current_comp)
//     CNOR[7:0]  — NOR of the two activated SRAM rows (from current_comp)
//     CB[7:0]    — Column Bias / accumulator value
//     SUM[7:0]   — 8-bit accumulation result
//     CO         — Final carry-out (overflow indicator)
//     Sign        — MSB of SUM (2's-complement sign)
//     Signproduct — CAND[7] XOR CB[7] (product sign for MUL mode)
// -----------------------------------------------------------------------------
module rrcam_8bit (
    input  wire [7:0] CAND,
    input  wire [7:0] CNOR,
    input  wire [7:0] CB,
    output wire [7:0] SUM,
    output wire       CO,
    output wire       Sign,
    output wire       Signproduct
);
    wire [8:0] carry;
    assign carry[0] = 1'b0;   // No initial carry-in

    genvar i;
    generate
        for (i = 0; i < 8; i = i + 1) begin : GEN_RRCAM
            rrcam_cell u_cell (
                .CANDx (CAND[i]),
                .CNORx (CNOR[i]),
                .CBx   (CB[i]),
                .CIx   (carry[i]),
                .SUMx  (SUM[i]),
                .COx   (carry[i+1])
            );
        end
    endgenerate

    assign CO          = carry[8];      // Overflow carry-out
    assign Sign        = SUM[7];        // MSB = sign (2's complement)
    assign Signproduct = CAND[7] ^ CB[7]; // Product sign (MSB XOR)
endmodule


// -----------------------------------------------------------------------------
// MODULE 8: sram_ctrl  (SRAM Control Circuit)
//
//   Generates the write address (one-hot WA/WAB), precharge control (PreD),
//   and write data bus (write_bus) from one of three sources:
//     Priority 1 (highest): CIM/MUL mode  → drives row addresses from CIM FSM
//     Priority 2          : BIST mode     → drives BIST pattern
//     Priority 3 (lowest) : Normal mode   → drives user-supplied data
//
//   WA and WAB are registered (clocked) to model the address latch in real
//   SRAM periphery. write_bus and wr_en_out are combinational for low latency.
// -----------------------------------------------------------------------------
module sram_ctrl (
    input  wire        clk,
    input  wire        rst_n,
    // From CIM control
    input  wire        Dffwr,        // Operand-latch strobe from CIM FSM
    input  wire        Cimprec,      // Precision mode
    input  wire        cim_active,   // CIM or MUL operation in progress
    input  wire [2:0]  WL_auto,      // CIM auto row address
    input  wire [2:0]  BL_auto,      // CIM auto column address
    // Normal user interface
    input  wire [2:0]  Word_addr,    // User row address
    input  wire [2:0]  Bit_addr,     // User column address (unused in this ctrl)
    input  wire [7:0]  Data_in,      // User write data
    input  wire        wr_en,        // User write enable
    // BIST
    input  wire [2:0]  bword_addr,   // BIST row address
    input  wire        BIST_data_in, // BIST data pattern (replicated to 8 bits)
    input  wire        BIST_wr_en,   // BIST write enable
    // Outputs
    output reg  [2:0]  WS,           // Row select (binary, feeds row_decoder)
    output reg  [7:0]  WA,           // One-hot write address (registered)
    output reg  [7:0]  WAB,          // Complement of WA (registered)
    output reg  [7:0]  PreD,         // Precharge control word (registered)
    output reg  [7:0]  write_bus,    // Write data (combinational)
    output reg         wr_en_out     // Qualified write enable (combinational)
);
    wire [7:0] bist_pattern = {8{BIST_data_in}};

    // Combinational: select write source based on priority
    always @(*) begin
        if (cim_active) begin
            WS        = WL_auto;
            write_bus = 8'h00;
            wr_en_out = 1'b0;     // CIM reads rows; write-back handled by wb_circuit
        end else if (BIST_wr_en) begin
            WS        = bword_addr;
            write_bus = bist_pattern;
            wr_en_out = 1'b1;
        end else begin
            WS        = Word_addr;
            write_bus = Data_in;
            wr_en_out = wr_en;
        end
    end

    // Registered: address one-hot and precharge
    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            WA   <= 8'h00;
            WAB  <= 8'hFF;
            PreD <= 8'hFF;
        end else begin
            WA   <= (8'h01 << WS);
            WAB  <= ~(8'h01 << WS);
            // PreD = 0x00 during write (precharge released); 0xFF when idle
            if (wr_en_out || BIST_wr_en)
                PreD <= 8'h00;
            else
                PreD <= 8'hFF;
        end
    end
endmodule


// -----------------------------------------------------------------------------
// MODULE 9: cim_ctrl  (CIM Control Circuit — FSM)
//
//   Five-state Mealy FSM that orchestrates a complete MAC pipeline:
//
//     IDLE       → Wait for MUL or CIM assertion
//     READ_OPS   → Assert row addresses; strobe Dffwr to latch operands
//     EXECUTE    → Assert DffC to capture adder result
//     WRITE_BACK → Assert Dffwrb; wb_circuit writes result to SRAM
//     DONE_ST    → Assert done; hold until input de-asserted → back to IDLE
//
//   New vs. original code:
//     - Address width corrected to 3 bits (matching arch diagram)
//     - WL_addend output added (addend row for dual SRAM read)
//     - Dffwr correctly asserted in READ_OPS
//     - BL_auto set in WRITE_BACK
//     - Is_Mul forwarded for write-back mux
//     - done output added
// -----------------------------------------------------------------------------
module cim_ctrl (
    input  wire        clk,
    input  wire        rst_n,
    // Operation selects
    input  wire        MUL,           // Multiply mode
    input  wire        CIM,           // Accumulate mode
    // Address operands
    input  wire [2:0]  Augend_addr,   // SRAM row of operand A
    input  wire [2:0]  Addend_addr,   // SRAM row of operand B
    input  wire [2:0]  Product_addr,  // SRAM row for MAC result
    input  wire [2:0]  Sign_addr,     // SRAM row for MUL sign result
    // Control outputs to wb_circuit
    output reg         Dffwr,         // Latch operand addresses
    output reg         Cimprec,       // Precision select (1=with carry)
    output reg         WRSel,         // Write-back source (1=arithmetic)
    output reg         Dffwrb,        // Write-back strobe
    output reg         DffC,          // Capture adder result
    // Row address outputs
    output reg  [2:0]  WL_auto,       // Augend row (also write-back destination)
    output reg  [2:0]  WL_addend,     // Addend row (for dual-row SRAM read)
    output reg  [2:0]  BL_auto,       // Column address
    output reg  [2:0]  S_addr,        // Write-back destination row
    // Flags
    output reg         Is_Mul,        // Forwarded MUL flag to wb_circuit
    output reg         done,          // Operation complete
    // Data bus mirror
    output wire [2:0]  CIM_Data       // Mirrors WL_auto (used as data token)
);
    // FSM state encoding
    localparam [2:0]
        IDLE       = 3'd0,
        READ_OPS   = 3'd1,
        EXECUTE    = 3'd2,
        WRITE_BACK = 3'd3,
        DONE_ST    = 3'd4;

    reg [2:0] state, nstate;

    // State register (synchronous, async reset)
    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) state <= IDLE;
        else        state <= nstate;
    end

    // Combinational next-state + output logic
    always @(*) begin
        // ---- Default outputs (avoid latches) ----
        nstate    = state;
        Dffwr     = 1'b0;
        Cimprec   = 1'b1;   // default: full precision
        WRSel     = 1'b0;
        Dffwrb    = 1'b0;
        DffC      = 1'b0;
        WL_auto   = 3'd0;
        WL_addend = 3'd0;
        BL_auto   = 3'd0;
        S_addr    = 3'd0;
        Is_Mul    = MUL;
        done      = 1'b0;

        case (state)
            // ------------------------------------------------
            IDLE: begin
                if (MUL || CIM)
                    nstate = READ_OPS;
            end

            // ------------------------------------------------
            // Activate both row addresses so SRAM dual-reads
            // BL_A and BL_B simultaneously. Dffwr strobes the
            // operand address registers in wb_circuit.
            // ------------------------------------------------
            READ_OPS: begin
                WL_auto   = Augend_addr;
                WL_addend = Addend_addr;
                Dffwr     = 1'b1;         // latch operand rows
                nstate    = EXECUTE;
            end

            // ------------------------------------------------
            // Keep row addresses asserted so CAND/CNOR and SUM
            // are stable. DffC captures the adder output.
            // Precision: Cimprec=1 for MAC (carry retained),
            //            Cimprec=0 for MUL (discard carry).
            // ------------------------------------------------
            EXECUTE: begin
                WL_auto   = Augend_addr;
                WL_addend = Addend_addr;
                DffC      = 1'b1;
                Cimprec   = ~MUL;
                nstate    = WRITE_BACK;
            end

            // ------------------------------------------------
            // Drive write-back address; Dffwrb strobes wb_circuit
            // to capture and forward result to SRAM write port.
            // MUL → write sign to Sign_addr row
            // CIM → write MAC result to Product_addr row
            // ------------------------------------------------
            WRITE_BACK: begin
                WRSel     = 1'b1;
                Dffwrb    = 1'b1;
                S_addr    = MUL ? Sign_addr   : Product_addr;
                WL_auto   = MUL ? Sign_addr   : Product_addr;
                BL_auto   = 3'd0;
                nstate    = DONE_ST;
            end

            // ------------------------------------------------
            DONE_ST: begin
                done = 1'b1;
                if (!MUL && !CIM)
                    nstate = IDLE;
            end

            default: nstate = IDLE;
        endcase
    end

    assign CIM_Data = WL_auto;   // Mirror WL_auto as data token on CIM bus
endmodule


// -----------------------------------------------------------------------------
// MODULE 10: wb_circuit  (Auto-Switching Write-Back Circuit)
//
//   Selects the correct result based on operation mode and precision,
//   then presents it to the SRAM write port for one clock cycle.
//
//   Result selection (combinational):
//     MUL mode          → {7'b0, Signproduct}   (1-bit sign of product)
//     CIM + Cimprec=1   → {CO, SUM[6:0]}        (carry included in MSB)
//     CIM + Cimprec=0   → SUM                   (raw 8-bit sum)
//     WRSel=0           → CIM_Data_bus           (passthrough / non-compute)
//
//   Dffwrb: one-cycle strobe that captures and asserts wr_en_wb for SRAM.
// -----------------------------------------------------------------------------
module wb_circuit (
    input  wire        clk,
    input  wire        rst_n,
    // Control from CIM FSM
    input  wire        Cimprec,
    input  wire        WRSel,
    input  wire        Is_Mul,
    input  wire        Dffwrb,       // Write-back strobe (one clock)
    input  wire        DffC,         // Capture strobe (latch arith result)
    input  wire [2:0]  S_addr,       // Destination row address
    input  wire [2:0]  WL_auto,      // Alternate row address
    input  wire [2:0]  BL_auto,      // Column address
    // From FS-GDI adder
    input  wire [7:0]  SUM,
    input  wire        CO,
    input  wire        Sign,
    input  wire        Signproduct,
    // Passthrough data bus
    input  wire [7:0]  CIM_Data_bus,
    // Write-back outputs → SRAM write port
    output reg  [7:0]  Write_Data_Bus,
    output reg  [2:0]  WL_out,
    output reg  [2:0]  BL_out,
    output reg         wr_en_wb       // Asserted for one cycle on write-back
);
    // ---- Combinational result selection ----
    wire [7:0] arith_result;
    assign arith_result = Is_Mul  ? {7'b000_0000, Signproduct} :
                          Cimprec ? {CO, SUM[6:0]}              :
                                    SUM;

    wire [7:0] next_data;
    assign next_data = WRSel ? arith_result : CIM_Data_bus;

    // ---- Registered write-back ----
    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            Write_Data_Bus <= 8'h00;
            WL_out         <= 3'd0;
            BL_out         <= 3'd0;
            wr_en_wb       <= 1'b0;
        end else begin
            wr_en_wb <= 1'b0;   // Default: no write (one-cycle pulse only)

            if (Dffwrb) begin
                Write_Data_Bus <= next_data;
                WL_out         <= WRSel ? S_addr : WL_auto;
                BL_out         <= BL_auto;
                wr_en_wb       <= 1'b1;
            end
        end
    end
endmodule
